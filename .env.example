# Public key configuration
JWKS_KID=u5aw0txey983f0i97zh8hbhtqpahhael
JWKS_ALG=ES384
JWKS_USE=sig

# OAuth client defaults
CLIENT_ID=u5aw0txey983f0i97zh8hbhtqpahhael
TOKEN_ENDPOINT=https://auth.sdid.uat:8443/auth/oauth2/token
ASSERTION_EXPIRES_IN_SECONDS=300

# Protect POST /client-assertion. Use a long random value.
ASSERTION_API_KEY=replace-with-long-random-secret

# Store PEM values as escaped newlines when adding them in Netlify UI.
# Example: -----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
JWKS_PRIVATE_KEY_PEM=
JWKS_PUBLIC_KEY_PEM=
